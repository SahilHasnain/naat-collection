{
  "name": "extract-audio",
  "version": "1.0.0",
  "description": "Appwrite Function to download YouTube audio and upload it to Appwrite Storage",
  "main": "src/main.ts",
  "type": "module",
  "dependencies": {
    "debug": "^4.4.0",
    "node-appwrite": "^21.1.0",
    "ytdlp-nodejs": "^3.4.4"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.7.0"
  },
  "scripts": {
    "build": "echo 'no build step needed'"
  },
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*.ts",
    "test-local.js"
  ]
}
