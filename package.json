{
  "name": "naat-collection-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "patch-package",
    "mobile": "npm run start --workspace=mobile",
    "mobile:android": "npm run android --workspace=mobile",
    "mobile:ios": "npm run ios --workspace=mobile",
    "mobile:web": "npm run web --workspace=mobile",
    "mobile:lint": "npm run lint --workspace=mobile",
    "mobile:test": "npm run test --workspace=mobile",
    "mobile:build:dev": "cd apps/mobile && eas build --platform android --profile development",
    "mobile:build:prev": "cd apps/mobile && eas build --platform android --profile preview",
    "mobile:build:prod": "cd apps/mobile && eas build --platform android --profile production",
    "web": "cd apps/web && npm run dev",
    "web:build": "cd apps/web && npm run build",
    "web:start": "cd apps/web && npm run start",
    "web:lint": "cd apps/web && npm run lint",
    "setup:ai-jobs": "node scripts/setup/setup-ai-jobs-collection.js",
    "setup:appwrite": "npm run setup:appwrite --workspace=mobile",
    "ingest:videos": "npm run ingest:videos --workspace=mobile",
    "worker:audio": "node vm-audio-worker/audio-worker.js",
    "batch:embed": "node scripts/batch-embed-naats.js",
    "batch:embed:test": "node scripts/batch-embed-naats.js --test",
    "batch:embed:skip": "node scripts/batch-embed-naats.js --skip-existing",
    "batch:check": "node scripts/check-embeddings.js",
    "check:non-owais": "node scripts/data-management/check-non-owais-naats.js",
    "cleanup:non-owais": "node cleanup-non-owais-naats.js",
    "upload:audio": "node scripts/utilities/download-audio.js",
    "delete:short-videos": "node scripts/data-management/delete-short-videos.js",
    "ai-cut": "node scripts/audio-processing/ai-cut-audio.js",
    "ai-cut:test": "node scripts/audio-processing/ai-cut-audio.js test",
    "ai-cut:find": "node scripts/audio-processing/ai-cut-audio.js find",
    "ai-cut:preview": "node scripts/audio-processing/ai-cut-audio.js preview",
    "ai-cut:process": "node scripts/audio-processing/ai-cut-audio.js process",
    "ai-cut:batch": "node scripts/audio-processing/ai-cut-audio.js batch",
    "ai-cut:random": "node scripts/audio-processing/process-random.js",
    "typecheck": "npx tsc --noEmit",
    "typecheck:mobile": "cd apps/mobile && npx tsc --noEmit",
    "typecheck:web": "cd apps/web && npx tsc --noEmit",
    "typecheck:functions": "cd functions/cut-audio-cron && npx tsc --noEmit",
    "prebuild": "cd apps/mobile && npx expo prebuild --clean",
    "ssh:ai": "ssh root@159.89.160.239",
    "ssh:build": "ssh Sahilhasnain@98.70.32.91",
"ssh:radio": "ssh root@168.144.23.181"

  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "dotenv": "^16.3.1",
    "node-appwrite": "^21.1.0",
    "node-fetch": "^3.3.2",
    "openai": "^4.77.0",
    "patch-package": "^8.0.1",
    "zod": "^3.25.76"
  },
  "dependencies": {
    "youtube-dl-exec": "^3.1.4"
  }
}
