# Appwrite Configuration
APPWRITE_API_KEY=your_appwrite_api_key_here

# Optional: Override default values
# APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
# APPWRITE_PROJECT_ID=695bb97700213f4ef5dd
# DATABASE_ID=695bba86001b50478ed4
# NAATS_COLLECTION_ID=695bc8e70038db72df5b
# AUDIO_BUCKET_ID=audio-files

# Audio cache behavior
# false (default): keep persistent cache across restarts (0 Appwrite reads)
# true: clear cache and fetch fresh playlist from database (5000 Appwrite reads)
CLEAR_AUDIO_CACHE_ON_START=false

# ═══════════════════════════════════════════════════════════════
# FALLBACK SYSTEM - When Database Reads Are Exhausted (402/429)
# ═══════════════════════════════════════════════════════════════
#
# LAYER 1: Database (always tried first)
#   - Has full metadata (title, duration)
#   - Can filter by radio=true
#   - Cost: 5000 reads
#
# LAYER 2: Configurable fallback (if database fails)
#
# Option A: storage_api (DEFAULT - Immediate solution)
#   - Fetches latest N audio files from storage bucket
#   - No metadata, no filtering (plays latest files)
#   - File names are YouTube IDs
#   - Cost: ~10 reads for 1000 files (500x cheaper!)
#   - Use when: Database quota exhausted RIGHT NOW
#
FALLBACK_SOURCE=storage_api
STORAGE_API_MAX_FILES=1000
#
# Option B: static_json (Future solution)
#   - Fetches from CDN (GitHub/jsDelivr)
#   - Has metadata from export
#   - Potentially stale data
#   - Cost: 0 reads (free!)
#   - Use when: You've exported data to static JSON
#
# FALLBACK_SOURCE=static_json
# STATIC_JSON_URL=https://cdn.jsdelivr.net/gh/username/repo@main/static-exports/radio-naats.json
#
# FINAL FALLBACK: Local cache (if all else fails)
# ═══════════════════════════════════════════════════════════════

# TIP: When you add new naats to the database:
# 1. Set CLEAR_AUDIO_CACHE_ON_START=true
# 2. Restart container: docker-compose restart
# 3. Set back to false for future restarts
# This way you only fetch when needed, saving 99.99% of reads!