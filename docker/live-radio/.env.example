# Appwrite Configuration
APPWRITE_API_KEY=your_appwrite_api_key_here

# Optional: Override default values
# APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
# APPWRITE_PROJECT_ID=695bb97700213f4ef5dd
# DATABASE_ID=695bba86001b50478ed4
# NAATS_COLLECTION_ID=695bc8e70038db72df5b

# Audio cache behavior
# false (default): keep persistent cache across restarts (0 Appwrite reads)
# true: clear cache and fetch fresh playlist from database (5000 Appwrite reads)
CLEAR_AUDIO_CACHE_ON_START=false

# TIP: When you add new naats to the database:
# 1. Set CLEAR_AUDIO_CACHE_ON_START=true
# 2. Restart container: docker-compose restart
# 3. Set back to false for future restarts
# This way you only fetch when needed, saving 99.99% of reads!