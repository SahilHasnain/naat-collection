# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools

default_platform(:android)

platform :android do
  desc "Runs all the tests"
  lane :test do
    gradle(task: "test")
  end

  private_lane :ensure_sentry_token do
    if ENV["SENTRY_AUTH_TOKEN"].to_s.empty?
      UI.user_error!("Missing SENTRY_AUTH_TOKEN. Set it in apps/mobile/.env.local before running fastlane.")
    end
  end

  desc "Submit a new Beta Build to Crashlytics Beta"
  lane :beta do
    ensure_sentry_token
    gradle(
      task: "clean assembleRelease",
      project_dir: "./"
    )
    crashlytics
  end

  desc "Deploy a new version to the Google Play"
  lane :deploy do
    ensure_sentry_token
    gradle(
      task: "clean assembleRelease",
      project_dir: "./"
    )
    upload_to_play_store
  end
end
